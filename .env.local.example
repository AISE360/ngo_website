# Copy this to .env.local and fill values (do NOT commit .env.local)

# Client (public) keys — safe to be public only if they are Supabase anon keys
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional compatibility alias used by some Supabase docs/examples
# VITE_SUPABASE_ANON_KEY=your-anon-key

# The following are server-only secrets — do NOT add these to .env for the client.
# Instead set them as Supabase Function secrets using `supabase secrets set`.
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_SECRET=your_razorpay_secret
# WA_PHONE_ID=your_whatsapp_phone_id
# WA_ACCESS_TOKEN=your_whatsapp_access_token
